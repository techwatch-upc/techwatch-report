@startuml Simulation

skinparam classAttributeIconSize 0
skinparam monochrome false
skinparam shadowing false

package "Simulation" {

    ' Value Objects
    class UserId <<Value Object>> {
        - value: Long
        + getValue(): Long
        + equals(other: UserId): Boolean
    }

    class PropertyId <<Value Object>> {
        - value: Long
        + getValue(): Long
        + equals(other: PropertyId): Boolean
    }

    class DeviceId <<Value Object>> {
        - value: Long
        + getValue(): Long
        + equals(other: DeviceId): Boolean
    }

    class SessionId <<Value Object>> {
        - value: Long
        + getValue(): Long
        + equals(other: SessionId): Boolean
    }

    class ConsumptionValue <<Value Object>> {
        - value: Double
        - unit: String
        + getValue(): Double
        + getUnit(): String
        + equals(other: ConsumptionValue): Boolean
    }

    class ParameterValue <<Value Object>> {
        - name: String
        - value: String
        + getName(): String
        + getValue(): String
        + equals(other: ParameterValue): Boolean
    }

    ' Enumerations
    enum SessionStatus <<Enum>> {
        ACTIVE
        COMPLETED
        CANCELLED
    }

    enum DeviceActionType <<Enum>> {
        TURN_ON
        TURN_OFF
        MODIFY_PARAMETER
    }

    ' Entities
    class SimulationSession <<Aggregate Root>> <<Entity>> {
        - id: SessionId
        - userId: UserId
        - propertyId: PropertyId
        - status: SessionStatus
        - startedAt: LocalDateTime
        - endedAt: LocalDateTime
        - updatedAt: LocalDateTime
        + getId(): SessionId
        + getUserId(): UserId
        + getPropertyId(): PropertyId
        + getStatus(): SessionStatus
        + getStartedAt(): LocalDateTime
        + getEndedAt(): LocalDateTime
        + start(): void
        + end(): void
        + cancel(): void
    }

    class DeviceAction <<Entity>> {
        - id: Long
        - sessionId: SessionId
        - deviceId: DeviceId
        - actionType: DeviceActionType
        - parameterValue: ParameterValue
        - executedAt: LocalDateTime
        + getId(): Long
        + getSessionId(): SessionId
        + getDeviceId(): DeviceId
        + getActionType(): DeviceActionType
        + getParameterValue(): ParameterValue
        + getExecutedAt(): LocalDateTime
    }

    class UsageData <<Entity>> {
        - id: Long
        - sessionId: SessionId
        - deviceId: DeviceId
        - consumptionValue: ConsumptionValue
        - recordedAt: LocalDateTime
        + getId(): Long
        + getSessionId(): SessionId
        + getDeviceId(): DeviceId
        + getConsumptionValue(): ConsumptionValue
        + getRecordedAt(): LocalDateTime
    }

    ' Repositories
    interface SimulationSessionRepository <<Repository>> {
        + findById(id: SessionId): Optional<SimulationSession>
        + findByUserId(userId: UserId): List<SimulationSession>
        + findByPropertyId(propertyId: PropertyId): List<SimulationSession>
        + findActiveByUserId(userId: UserId): Optional<SimulationSession>
        + save(session: SimulationSession): SimulationSession
        + deleteById(id: SessionId): void
    }

    interface UsageDataRepository <<Repository>> {
        + findById(id: Long): Optional<UsageData>
        + findBySessionId(sessionId: SessionId): List<UsageData>
        + findByDeviceId(deviceId: DeviceId): List<UsageData>
        + save(usageData: UsageData): UsageData
    }

    ' Services
    class SimulationService <<Service>> {
        - sessionRepository: SimulationSessionRepository
        - usageDataRepository: UsageDataRepository
        + startSession(userId: UserId, propertyId: PropertyId): SimulationSession
        + endSession(sessionId: SessionId): SimulationSession
        + cancelSession(sessionId: SessionId): SimulationSession
        + executeAction(sessionId: SessionId, action: DeviceAction): DeviceAction
        + generateUsageData(sessionId: SessionId, deviceId: DeviceId): UsageData
        + getSessionById(sessionId: SessionId): SimulationSession
        + getSessionsByUserId(userId: UserId): List<SimulationSession>
        + getUsageDataBySessionId(sessionId: SessionId): List<UsageData>
    }

    ' Relations
    SimulationSession "1" *-- "0..*" DeviceAction : records >
    SimulationSession "1" *-- "0..*" UsageData : generates >
    SimulationSession --> SessionStatus : uses >
    SimulationSession *-- SessionId : id >
    SimulationSession *-- UserId : userId >
    SimulationSession *-- PropertyId : propertyId >
    DeviceAction --> DeviceActionType : uses >
    DeviceAction *-- SessionId : sessionId >
    DeviceAction *-- DeviceId : deviceId >
    DeviceAction *-- ParameterValue : parameterValue >
    UsageData *-- SessionId : sessionId >
    UsageData *-- DeviceId : deviceId >
    UsageData *-- ConsumptionValue : consumptionValue >
    SimulationService --> SimulationSessionRepository : uses >
    SimulationService --> UsageDataRepository : uses >
    SimulationSessionRepository ..> SimulationSession : manages >
    UsageDataRepository ..> UsageData : manages >
}

@enduml