@startuml Analytics

skinparam classAttributeIconSize 0
skinparam monochrome false
skinparam shadowing false

package "Analytics" {

    ' Value Objects
    class UserId <<Value Object>> {
        - value: Long
        + getValue(): Long
        + equals(other: UserId): Boolean
    }

    class PropertyId <<Value Object>> {
        - value: Long
        + getValue(): Long
        + equals(other: PropertyId): Boolean
    }

    class DeviceId <<Value Object>> {
        - value: Long
        + getValue(): Long
        + equals(other: DeviceId): Boolean
    }

    class MetricValue <<Value Object>> {
        - value: Double
        - unit: String
        + getValue(): Double
        + getUnit(): String
        + equals(other: MetricValue): Boolean
    }

    class Threshold <<Value Object>> {
        - value: Double
        - unit: String
        + getValue(): Double
        + getUnit(): String
        + equals(other: Threshold): Boolean
    }

    ' Enumerations
    enum MetricType <<Enum>> {
        ENERGY_CONSUMPTION
        USAGE_FREQUENCY
        PEAK_HOURS
        AVERAGE_CONSUMPTION
    }

    enum AlertSeverity <<Enum>> {
        LOW
        MEDIUM
        HIGH
    }

    enum ReportPeriod <<Enum>> {
        DAILY
        WEEKLY
        MONTHLY
        CUSTOM
    }

    ' Entities
    class Metric <<Aggregate Root>> <<Entity>> {
        - id: Long
        - deviceId: DeviceId
        - propertyId: PropertyId
        - metricType: MetricType
        - metricValue: MetricValue
        - calculatedAt: LocalDateTime
        + getId(): Long
        + getDeviceId(): DeviceId
        + getPropertyId(): PropertyId
        + getMetricType(): MetricType
        + getMetricValue(): MetricValue
        + getCalculatedAt(): LocalDateTime
    }

    class ConsumptionReport <<Entity>> {
        - id: Long
        - propertyId: PropertyId
        - userId: UserId
        - period: ReportPeriod
        - startDate: LocalDate
        - endDate: LocalDate
        - generatedAt: LocalDateTime
        - isAutomatic: Boolean
        + getId(): Long
        + getPropertyId(): PropertyId
        + getUserId(): UserId
        + getPeriod(): ReportPeriod
        + getStartDate(): LocalDate
        + getEndDate(): LocalDate
        + getGeneratedAt(): LocalDateTime
        + isAutomatic(): Boolean
    }

    class ReportItem <<Entity>> {
        - id: Long
        - reportId: Long
        - deviceId: DeviceId
        - deviceName: String
        - totalConsumption: MetricValue
        - usageFrequency: Integer
        + getId(): Long
        + getReportId(): Long
        + getDeviceId(): DeviceId
        + getDeviceName(): String
        + getTotalConsumption(): MetricValue
        + getUsageFrequency(): Integer
    }

    class ConsumptionAlert <<Entity>> {
        - id: Long
        - deviceId: DeviceId
        - propertyId: PropertyId
        - userId: UserId
        - severity: AlertSeverity
        - message: String
        - threshold: Threshold
        - currentValue: MetricValue
        - triggeredAt: LocalDateTime
        - isRead: Boolean
        - updatedAt: LocalDateTime
        + getId(): Long
        + getDeviceId(): DeviceId
        + getPropertyId(): PropertyId
        + getSeverity(): AlertSeverity
        + getMessage(): String
        + getThreshold(): Threshold
        + getCurrentValue(): MetricValue
        + isRead(): Boolean
        + markAsRead(): void
    }

    ' Repositories
    interface MetricRepository <<Repository>> {
        + findById(id: Long): Optional<Metric>
        + findByDeviceId(deviceId: DeviceId): List<Metric>
        + findByPropertyId(propertyId: PropertyId): List<Metric>
        + findByMetricType(metricType: MetricType): List<Metric>
        + findByPropertyIdAndCalculatedAtBetween(propertyId: PropertyId, start: LocalDateTime, end: LocalDateTime): List<Metric>
        + save(metric: Metric): Metric
    }

    interface ConsumptionReportRepository <<Repository>> {
        + findById(id: Long): Optional<ConsumptionReport>
        + findByUserId(userId: UserId): List<ConsumptionReport>
        + findByPropertyId(propertyId: PropertyId): List<ConsumptionReport>
        + save(report: ConsumptionReport): ConsumptionReport
        + deleteById(id: Long): void
    }

    interface ConsumptionAlertRepository <<Repository>> {
        + findById(id: Long): Optional<ConsumptionAlert>
        + findByUserId(userId: UserId): List<ConsumptionAlert>
        + findByPropertyId(propertyId: PropertyId): List<ConsumptionAlert>
        + findUnreadByUserId(userId: UserId): List<ConsumptionAlert>
        + save(alert: ConsumptionAlert): ConsumptionAlert
    }

    ' Services
    class AnalyticsService <<Service>> {
        - metricRepository: MetricRepository
        - alertRepository: ConsumptionAlertRepository
        + calculateMetrics(deviceId: DeviceId, sessionId: Long): List<Metric>
        + getMetricsByDeviceId(deviceId: DeviceId): List<Metric>
        + getMetricsByPropertyId(propertyId: PropertyId): List<Metric>
        + checkThresholdAndAlert(metric: Metric): Optional<ConsumptionAlert>
        + getAlertsByUserId(userId: UserId): List<ConsumptionAlert>
        + markAlertAsRead(alertId: Long): void
    }

    class ReportService <<Service>> {
        - reportRepository: ConsumptionReportRepository
        - metricRepository: MetricRepository
        + generateAutomaticReport(propertyId: PropertyId, period: ReportPeriod): ConsumptionReport
        + generateReportOnDemand(propertyId: PropertyId, startDate: LocalDate, endDate: LocalDate): ConsumptionReport
        + getReportById(reportId: Long): ConsumptionReport
        + getReportsByUserId(userId: UserId): List<ConsumptionReport>
    }

    ' Relations
    ConsumptionReport "1" *-- "1..*" ReportItem : contains >
    ConsumptionReport --> ReportPeriod : uses >
    ConsumptionReport *-- PropertyId : propertyId >
    ConsumptionReport *-- UserId : userId >
    ConsumptionAlert --> AlertSeverity : uses >
    ConsumptionAlert *-- DeviceId : deviceId >
    ConsumptionAlert *-- PropertyId : propertyId >
    ConsumptionAlert *-- UserId : userId >
    ConsumptionAlert *-- Threshold : threshold >
    ConsumptionAlert *-- MetricValue : currentValue >
    Metric --> MetricType : uses >
    Metric *-- DeviceId : deviceId >
    Metric *-- PropertyId : propertyId >
    Metric *-- MetricValue : metricValue >
    ReportItem *-- DeviceId : deviceId >
    ReportItem *-- MetricValue : totalConsumption >
    AnalyticsService --> MetricRepository : uses >
    AnalyticsService --> ConsumptionAlertRepository : uses >
    ReportService --> ConsumptionReportRepository : uses >
    ReportService --> MetricRepository : uses >
    MetricRepository ..> Metric : manages >
    ConsumptionReportRepository ..> ConsumptionReport : manages >
    ConsumptionAlertRepository ..> ConsumptionAlert : manages >
}

@enduml